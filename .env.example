APP_NAME="Login Seguro"
SERVER_NUMBER=1
APP_ENV=local
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_FORCE_HTTPS=false
TRUSTED_PROXIES=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=app_runtime
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_COOKIE=laravel_session
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@loginseguro.test"
MAIL_FROM_NAME="${APP_NAME}"

RATE_LIMIT_API_ATTEMPTS=60
RATE_LIMIT_API_DECAY_MINUTES=1
RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_DECAY_MINUTES=1
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_DECAY_MINUTES=1
RATE_LIMIT_TOTP_ATTEMPTS=5
RATE_LIMIT_TOTP_DECAY_MINUTES=1
RATE_LIMIT_RECOVERY_CODES_ATTEMPTS=3
RATE_LIMIT_RECOVERY_CODES_DECAY_MINUTES=10
RATE_LIMIT_ADMIN_ATTEMPTS=25
RATE_LIMIT_ADMIN_DECAY_MINUTES=1
RATE_LIMIT_PASSWORD_RESET_ATTEMPTS=3
RATE_LIMIT_PASSWORD_RESET_DECAY_MINUTES=10
RATE_LIMIT_EMAIL_RESEND_ATTEMPTS=3
RATE_LIMIT_EMAIL_RESEND_DECAY_MINUTES=10
RATE_LIMIT_ADMIN_REAUTH_ATTEMPTS=5
RATE_LIMIT_ADMIN_REAUTH_DECAY_MINUTES=10
RATE_LIMIT_ADMIN_CRITICAL_ATTEMPTS=25
RATE_LIMIT_ADMIN_CRITICAL_DECAY_MINUTES=1

TOTP_ISSUER="${APP_NAME}"
TOTP_PERIOD=30
TOTP_DIGITS=6
TOTP_WINDOW=1

SEED_USER_JORGEIBARRA_EMAIL=
SEED_USER_JORGEIBARRA_PASSWORD=
SEED_USER_SAUTREJO_EMAIL=
SEED_USER_SAUTREJO_PASSWORD=
SEED_USER_SAUL_EMAIL=
SEED_USER_SAUL_PASSWORD=
SEED_USER_JESUS_EMAIL=
SEED_USER_JESUS_PASSWORD=
SEED_USER_DANI_EMAIL=
SEED_USER_DANI_PASSWORD=
SEED_USER_AZA_EMAIL=
SEED_USER_AZA_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
